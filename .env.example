DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-local-secret"
NEXT_PUBLIC_SITE_URL="https://smartfit.am"

SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_EMAIL="admin@smartfit.local"
SEED_ADMIN_PASSWORD="replace-with-a-strong-local-admin-password"

SEED_REGISTRATION_USERNAME="registration"
SEED_REGISTRATION_EMAIL="registration@smartfit.local"
SEED_REGISTRATION_PASSWORD="replace-with-a-strong-local-registration-password"

STORAGE_PROVIDER="r2"
CLOUD_NAME="replace-with-storage-bucket-or-container-name"
ACCESS_KEY_ID="replace-with-storage-access-key-id"
SECRET_ACCESS_KEY="replace-with-storage-secret-access-key"
STORAGE_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
STORAGE_REGION="auto"
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"

CUSTOMER_DOCUMENT_MAX_FILE_SIZE_MB="10"
CUSTOMER_DOCUMENT_ALLOWED_MIME_TYPES="application/pdf,image/jpeg,image/png"
